Algoritmo sin_titulo
	
	definir lado_tamańo, columna, fila Como entero
	
	escribir "Escriba el tamańo del lado del cuadrado"
	leer lado_tamańo

	para columna <- 1 hasta lado_tamańo Hacer  
		
		Para fila <- 1 hasta lado_tamańo Hacer 
			
			Escribir Sin Saltar"*"
			
		FinPara
		
		Escribir "";
		
	FinPara
	
FinAlgoritmo
